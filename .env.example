# ---- App ----
LOG_LEVEL=INFO
DATA_DIR=data
DOCUMENTS_DIR=data/documents
CHROMA_DIR=data/chroma_db

# ---- Embeddings ----
EMBEDDING_PROVIDER=huggingface
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ---- Vector Store ----
# Supported: chroma, pinecone
VECTOR_STORE=chroma
PINECONE_API_KEY=
PINECONE_INDEX=rag-index

# ---- Retrieval ----
# Supported: similarity, mmr, hybrid
RETRIEVAL_STRATEGY=mmr
RETRIEVAL_TOP_K=5
RETRIEVAL_CANDIDATE_K=20
RETRIEVAL_MMR_LAMBDA_MULT=0.5
RETRIEVAL_RRF_K=60
RETRIEVAL_ENABLE_LOST_MIDDLE_REORDERING=true
RETRIEVAL_ENABLE_RERANKING=true
RERANKER_MODEL=BAAI/bge-reranker-base
RERANKER_FALLBACK_MODEL=
RERANKER_BATCH_SIZE=16
RERANKER_ENABLE_WARMUP=false
RETRIEVAL_FILTER_SOURCE=
RETRIEVAL_FILTER_FILE_TYPE=
RETRIEVAL_FILTER_METADATA_JSON=
# Optional comma-separated allow-list for metadata filter keys in deployed environments.
RETRIEVAL_ALLOWED_METADATA_FILTER_KEYS=

# ---- Query Planning ----
QUERY_EXPANSION_MAX_VARIANTS=2
QUERY_DECOMPOSITION_MAX_SUBQUESTIONS=2
QUERY_PLANNING_ADAPTIVE_ENABLED=true
QUERY_PLANNING_LOW_CONFIDENCE_THRESHOLD=0.45
QUERY_PLANNING_MIN_WORDS_FOR_EXPANSION=8
QUERY_PLANNING_MIN_WORDS_FOR_DECOMPOSITION=12

# ---- Context and Memory ----
MAX_CONTEXT_TOKENS=1800
CONTEXT_COMPRESSION_MAX_SENTENCES=3
CONVERSATION_MEMORY_MAX_TURNS=4
COST_OPTIMIZATION_MAX_CONTEXT_CHUNKS=4
COST_OPTIMIZATION_ENABLE_PROMPT_SIMPLIFICATION=true
COST_OPTIMIZATION_MAX_QUERY_PLANNING_CALLS=1
GUARDRAILS_ENABLE_CLAIM_SUPPORT_CHECK=true
GUARDRAILS_MIN_CLAIM_TOKEN_COVERAGE=0.8

# ---- LLM Gateway ----
LLM_PRIMARY_MODEL=gemini/gemini-2.5-flash
LLM_FALLBACK_MODELS=groq/llama-3.3-70b-versatile,cerebras/llama3.1-8b
LLM_CODE_MODEL=gemini/gemini-2.5-flash
LLM_SUMMARY_MODEL=groq/llama-3.3-70b-versatile
LLM_GENERAL_MODEL=gemini/gemini-2.5-flash
LLM_TEMPERATURE=0.0
LLM_MAX_OUTPUT_TOKENS=1024
LLM_TIMEOUT_SECONDS=60.0
LLM_MAX_RETRIES=3
LLM_RETRY_BACKOFF_SECONDS=1.0
LLM_ENABLE_COST_TRACKING=true
LLM_MAX_ESTIMATED_PROMPT_TOKENS=6000
LLM_ESTIMATED_COST_PER_1K_TOKENS=0.0
LLM_MAX_ESTIMATED_COST_USD_PER_REQUEST=0.0
LLM_RATE_LIMIT_REQUESTS=30
LLM_RATE_LIMIT_WINDOW_SECONDS=60

# ---- Provider API Keys ----
GOOGLE_API_KEY=
GOOGLE_API_KEY2=
GOOGLE_API_KEY3=
GROQ_API_KEY=
CEREBRAS_API_KEY=

# ---- Startup and Ingestion ----
STARTUP_VALIDATE_CONFIGURATION=true
ENABLE_HEALTH_CHECKS=true
INGESTION_RETRY_ATTEMPTS=2
